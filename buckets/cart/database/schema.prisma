model Cart {
  id        String     @id @default(cuid())
  userId    String?
  sessionId String?
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int      @default(1)
  price     Float
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
